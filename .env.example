# Crypto Trading Bot - Environment Variables
# Copy this file to .env and fill in your API keys.
# NEVER commit your .env file.

# ===========================================
# Kraken Exchange API
# ===========================================
# https://www.kraken.com/u/security/api
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# ===========================================
# Reddit API (PRAW)
# ===========================================
# Create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# ===========================================
# StockTwits
# ===========================================
# The public streams endpoint does not require credentials.
# Rate limit: ~200 requests/hour per IP.

# ===========================================
# Database
# ===========================================
# SQLite default. For PostgreSQL: postgresql://user:pass@host:5432/trading_bot
DATABASE_URL=sqlite:///crypto_trading_bot/data/trading_bot.db

# ===========================================
# Optional
# ===========================================
# LOG_LEVEL=INFO
# LOG_FILE=crypto_trading_bot/logs/trading_bot.log
