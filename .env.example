# Crypto Trading Bot - Environment Variables
# Copy this file to .env and fill in your API keys
# NEVER commit your .env file to version control!

# ===========================================
# Kraken Exchange API
# ===========================================
# Get your API keys from: https://www.kraken.com/u/security/api
# Recommended: Create a separate API key for paper vs live trading
# Enable only the permissions you need (view balance, create orders)

KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# ===========================================
# Reddit API (PRAW)
# ===========================================
# Create an app at: https://www.reddit.com/prefs/apps
# Choose "script" type application
# Client ID is under the app name
# Client Secret is labeled "secret"

REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# ===========================================
# Twitter/X API
# ===========================================
# Get your API keys from: https://developer.twitter.com/
# You need at least Basic tier for recent search API
# Bearer token is the most important for read-only access

TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here

# ===========================================
# Database
# ===========================================
# Default uses SQLite (no configuration needed)
# For PostgreSQL: postgresql://user:password@localhost:5432/trading_bot

DATABASE_URL=sqlite:///crypto_trading_bot/data/trading_bot.db

# ===========================================
# Optional Settings
# ===========================================
# These have defaults but can be overridden

# LOG_LEVEL=INFO
# LOG_FILE=crypto_trading_bot/logs/trading_bot.log
